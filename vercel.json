{
  "version": 2,
  "framework": "vite",
  "regions": ["sin1"],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/node-health",
      "destination": "/api/user.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/user.js"
    },
    {
      "source": "/watchlist/(.*)",
      "destination": "/api/user.js"
    },
    {
      "source": "/progress/(.*)",
      "destination": "/api/user.js"
    },
    {
      "source": "/settings/(.*)",
      "destination": "/api/user.js"
    },
    {
      "source": "/notifications/(.*)",
      "destination": "/api/user.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
